# ==================== CONFIGURAÇÃO NOTION ====================
# Chave de API do Notion
# Como obter: https://www.notion.so/my-integrations
# 1. Acesse https://www.notion.so/my-integrations
# 2. Clique em "New integration"
# 3. Dê um nome (ex: "Pomodoro Dev Tracker")
# 4. Selecione o workspace
# 5. Copie o "Internal Integration Token"
NOTION_API_KEY=seu_token_notion_aqui

# ID da database Notion
# Como obter:
# 1. Crie uma database no Notion com as propriedades:
#    - "Intervalo" (Title)
#    - "Inicio" (Date)
#    - "Fim" (Date)
#    - "Tecnologia" (Select com opções: Python, C#, SQL, n8n, Arquitetura, Outros)
# 2. Compartilhe a database com a integração criada
# 3. A URL da database: https://www.notion.so/seu-workspace/[DATABASE_ID]?v=...
#    Copie apenas o [DATABASE_ID] (32 caracteres alfanuméricos)
DATABASE_ID=seu_database_id_aqui
